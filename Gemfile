# This Gemfile is only needed if you want to build the site locally with Ruby.
# GitHub Pages builds the site for you on every push, so most contributors
# never need Ruby installed at all — just edit Markdown files on github.com.
#
# To preview locally (optional):
#   gem install bundler
#   bundle install
#   bundle exec jekyll serve
# then open http://localhost:4000/mosaic-website/

source "https://rubygems.org"

# The github-pages gem pins Jekyll and all plugins to exactly the versions
# GitHub Pages runs, so a local preview matches production.
gem "github-pages", group: :jekyll_plugins

# Windows and JRuby helpers (harmless elsewhere).
gem "tzinfo-data", platforms: [:mingw, :mswin, :x64_mingw, :jruby]
gem "wdm", "~> 0.1.1", platforms: [:mingw, :mswin, :x64_mingw]
